NETWORK_PROXY_CLIENT_MANAGER_URL=http://host.docker.internal:9001
NETWORK_PROXY_CLIENT_SUBSCRIPTION_TOKEN=sub-db
NETWORK_PROXY_CLIENT_SOCKS_PORT=10808
# HTTP proxy inbound (for tools that only speak HTTP proxies).
# Set to 0 to disable. SOCKS5 above is the canonical inbound.
NETWORK_PROXY_CLIENT_HTTP_PORT=10809
# Override the host/port from the subscription so the client can reach the
# node through the Docker host gateway in local test environments.
NETWORK_PROXY_CLIENT_OVERRIDE_HOST=host.docker.internal
NETWORK_PROXY_CLIENT_OVERRIDE_PORT=21001
# Leave blank to use the first node from the subscription.
NETWORK_PROXY_CLIENT_NODE_NAME=
NETWORK_PROXY_CLIENT_INTERVAL=10
NETWORK_PROXY_CLIENT_V2RAY_POLL_SECONDS=2
