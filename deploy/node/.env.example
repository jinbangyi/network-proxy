NETWORK_PROXY_NODE_MANAGER_URL=http://host.docker.internal:9001
NETWORK_PROXY_NODE_NAME=node-1
NETWORK_PROXY_NODE_PUBLIC_HOST=127.0.0.1
NETWORK_PROXY_NODE_REGION=local
NETWORK_PROXY_NODE_REQUESTED_PROTOCOLS=vmess
NETWORK_PROXY_NODE_REQUESTED_MODES=direct
NETWORK_PROXY_NODE_REQUESTED_PORT=21001
NETWORK_PROXY_NODE_PUBLISHED_PORT=21001
NETWORK_PROXY_NODE_AGENT_VERSION=0.1.0
NETWORK_PROXY_NODE_INTERVAL=10
NETWORK_PROXY_NODE_V2RAY_POLL_SECONDS=2
NETWORK_PROXY_NODE_VALIDATE_COMMAND=sh -c 'test -s /app/data/node-v2ray-config.json'
NETWORK_PROXY_NODE_APPLY_COMMAND=sh -c 'touch /app/data/node-v2ray-reload.marker'