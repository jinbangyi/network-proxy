{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "proxy-in",
      "listen": "0.0.0.0",
      "port": {{ listen_port }},
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": {{ client_id | tojson }},
            "alterId": 0,
            "security": {{ security | tojson }}
          }
        ]
      },
      "streamSettings": {
        "network": {{ network | tojson }},
        "security": {{ transport_security | tojson }}
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {}
    }
  ]
}